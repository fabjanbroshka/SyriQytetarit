---
---

<section class="why-section" id="why">
  <div class="container">

    <div class="why-grid">

      <!-- Majtas: tekst -->
      <div class="why-text">
        <span class="eyebrow">Pse?</span>
        <h2 class="section-title">
          Problemet e qytetit mbeten<br/>
          të pazgjidhura sepse<br/>
          nuk dokumentohen.
        </h2>
        <p class="why-body">
          Kur shfaqet një gropë ose prishet një dritë rruge, shumica e njerëzve e vërejnë —
          pothuajse askush nuk e raporton. Problemi mbetet i padokumentuar.
          Pa të dhëna nuk ka prioritet. Pa prioritet nuk ka zgjidhje.
        </p>
        <p class="why-body">
          Syri Qytetar e bën të thjeshtë. Raporto brenda 30 sekondave dhe të dhënat arrijnë tek ata që mund ta zgjedhin.
        </p>

        <div class="why-stats">
          <div class="stat">
            <span class="stat-val">30s</span>
            <span class="stat-lbl">për të raportuar një problem</span>
          </div>
          <div class="stat-sep"></div>
          <div class="stat">
            <span class="stat-val">0</span>
            <span class="stat-lbl">burokraci e nevojshme</span>
          </div>
          <div class="stat-sep"></div>
          <div class="stat">
            <span class="stat-val">100%</span>
            <span class="stat-lbl">e drejtuar nga qytetarët</span>
          </div>
        </div>
      </div>

      <!-- Djathtas: diagrami para/pas -->
      <div class="why-visual">
        <div class="flow-label flow-label-bad">Pa Syrin Qytetar</div>
        <div class="flow bad-flow">
          <div class="flow-step">
            <div class="flow-icon icon-red">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
              </svg>
            </div>
            <div class="flow-text">
              <strong>Problemi shfaqet</strong>
              <span>Gropë, dritë e prishur, parkim ilegal…</span>
            </div>
          </div>
          <div class="flow-line bad-line"></div>
          <div class="flow-step">
            <div class="flow-icon icon-red">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/>
              </svg>
            </div>
            <div class="flow-text">
              <strong>Qytetarët vërejnë</strong>
              <span>Të gjithë e shohin, askush nuk e raporton.</span>
            </div>
          </div>
          <div class="flow-line bad-line"></div>
          <div class="flow-step">
            <div class="flow-icon icon-red">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>
              </svg>
            </div>
            <div class="flow-text">
              <strong>Asgjë nuk ndodh</strong>
              <span>Pa të dhëna → pa prioritet → pa zgjidhje.</span>
            </div>
          </div>
        </div>

        <div class="flow-divider">
          <div class="divider-line"></div>
          <span class="divider-badge">vs</span>
          <div class="divider-line"></div>
        </div>

        <div class="flow-label flow-label-good">Me Syrin Qytetar</div>
        <div class="flow good-flow">
          <div class="flow-step">
            <div class="flow-icon icon-green">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/>
              </svg>
            </div>
            <div class="flow-text">
              <strong>Raport 30-sekondësh</strong>
              <span>Foto, kategori, GPS — gati.</span>
            </div>
          </div>
          <div class="flow-line good-line"></div>
          <div class="flow-step">
            <div class="flow-icon icon-green">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
              </svg>
            </div>
            <div class="flow-text">
              <strong>Të dhëna të strukturuara</strong>
              <span>Raporti verifikohet dhe regjistrohet.</span>
            </div>
          </div>
          <div class="flow-line good-line"></div>
          <div class="flow-step">
            <div class="flow-icon icon-green">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </div>
            <div class="flow-text">
              <strong>Problemi zgjidhet</strong>
              <span>Të dhënat arrijnë tek ata që mund të veprojnë.</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .why-section {
    background: #0a0f1a;
    padding: 112px 0;
  }
  .container {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .why-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .eyebrow {
    display: inline-block;
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: rgba(147,197,253,.75);
    margin-bottom: 16px;
  }
  .section-title {
    font-size: clamp(1.9rem, 3.5vw, 3rem);
    font-weight: 800;
    letter-spacing: -.035em;
    line-height: 1.1;
    color: #fff;
    margin-bottom: 24px;
  }
  .why-body {
    font-size: 1rem;
    color: rgba(255,255,255,.55);
    line-height: 1.8;
    margin-bottom: 16px;
  }

  .why-stats {
    display: flex;
    align-items: center;
    gap: 32px;
    margin-top: 40px;
    padding-top: 32px;
    border-top: 1px solid rgba(255,255,255,.08);
    flex-wrap: wrap;
  }
  .stat { display: flex; flex-direction: column; gap: 4px; }
  .stat-val {
    font-size: 2.2rem;
    font-weight: 900;
    letter-spacing: -.04em;
    line-height: 1;
    color: #fff;
  }
  .stat-lbl {
    font-size: .68rem;
    color: rgba(255,255,255,.35);
    text-transform: uppercase;
    letter-spacing: .1em;
  }
  .stat-sep {
    width: 1px; height: 40px;
    background: rgba(255,255,255,.1);
    flex-shrink: 0;
  }

  .why-visual { display: flex; flex-direction: column; }

  .flow-label {
    font-size: .65rem;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    margin-bottom: 12px;
    padding: 0 4px;
  }
  .flow-label-bad  { color: rgba(239,68,68,.7); }
  .flow-label-good { color: rgba(16,185,129,.7); }

  .flow { display: flex; flex-direction: column; }

  .flow-step {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 14px 16px;
    border-radius: 12px;
    margin-bottom: 2px;
  }
  .bad-flow  .flow-step { background: rgba(239,68,68,.05);  border: 1px solid rgba(239,68,68,.1); }
  .good-flow .flow-step { background: rgba(16,185,129,.05); border: 1px solid rgba(16,185,129,.12); }

  .flow-icon {
    width: 32px; height: 32px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .icon-red   { background: rgba(239,68,68,.15);  color: #ef4444; }
  .icon-green { background: rgba(16,185,129,.15); color: #10b981; }

  .flow-text { display: flex; flex-direction: column; gap: 2px; }
  .flow-text strong { font-size: .82rem; font-weight: 700; color: #fff; }
  .flow-text span   { font-size: .75rem; color: rgba(255,255,255,.45); line-height: 1.5; }

  .flow-line {
    width: 1.5px; height: 8px;
    margin-left: 29px;
  }
  .bad-line  { background: rgba(239,68,68,.25); }
  .good-line { background: rgba(16,185,129,.3); }

  .flow-divider {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 20px 0 16px;
  }
  .divider-line { flex: 1; height: 1px; background: rgba(255,255,255,.08); }
  .divider-badge {
    font-size: .7rem;
    font-weight: 700;
    color: rgba(255,255,255,.3);
    letter-spacing: .05em;
    padding: 3px 10px;
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 100px;
  }

  @media (max-width: 900px) {
    .why-section { padding: 80px 0; }
    .container { padding: 0 20px; }
    .why-grid { grid-template-columns: 1fr; gap: 56px; }
    .why-stats { gap: 24px; }
  }
  @media (max-width: 560px) {
    .why-section { padding: 64px 0; }
    .container { padding: 0 16px; }
    .section-title { font-size: clamp(1.75rem, 7vw, 2.2rem); }
    .why-stats { flex-direction: column; align-items: flex-start; gap: 20px; }
    .stat-sep { display: none; }
    .stat-val { font-size: 1.8rem; }
  }
</style>
