---
---
<section class="hero" id="hero">
  <div class="hero-bg">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
  </div>

  <div class="hero-inner">
    <p class="hero-label">Syri Qytetar</p>

    <h1 class="hero-title">
      Shiko.<br/>
      Raporto.<br/>
      <span class="hero-accent">Ndrysho.</span>
    </h1>

    <p class="hero-desc">
      Një aplikacion për raportimin e problemeve të qytetit — si parkimi i parregullt, rrugët e dëmtuara, ndotja dhe shumë të tjera.
    </p>

    <div class="hero-flow">
      <span>Shiko</span>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      <span>Raporto</span>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      <span>Ndrysho</span>
    </div>

    <div class="hero-actions">
      <a href="#who" class="btn-store">
        <svg width="20" height="20" viewBox="0 0 814 1000" fill="currentColor"><path d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76 0-103.7 40.8-165.9 40.8s-105-57.8-155.5-127.4C46 376.8 0 246.4 0 121.2 0 56.9 20.2 14.2 60.3 14.2c35.3 0 68.7 21.1 95.7 21.1 37.1 0 83.3-22.4 127.3-22.4 45.1 0 104.1 16.1 140.4 68.5h1.9c-4.5-21.6-10.9-50.3-10.9-74.6 0-58.4 33.5-100.7 76-117.5 5.8 15.3 9.6 33.5 9.6 52.4 0 64.9-46.5 117.5-84.8 117.5h-1.9c3.8 23 47.2 58.4 93.5 58.4 35.3 0 65.5-18.2 91.3-44.5l15.4 8.7z"/></svg>
        <div><span>Shkarko në</span><strong>App Store</strong></div>
      </a>
      <a href="#who" class="btn-store">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M3.18 23.76c.32.18.68.24 1.04.17l11.3-11.3-2.98-2.98L3.18 23.76z"/><path d="M22.38 10.54l-3.03-1.72-3.35 3.35 3.35 3.35 3.04-1.73c.87-.49.87-1.76-.01-2.25z"/><path d="M1.26 1.1C1.1 1.36 1 1.67 1 2.02v19.96c0 .35.1.66.26.92l.1.1L13.54 10.8v-.29L1.36 1z"/><path d="M13.54 14.21l-2.17-2.17L1.26 22.97c.37.39.95.43 1.38.1l10.9-8.86z"/></svg>
        <div><span>Merr në</span><strong>Google Play</strong></div>
      </a>
    </div>
  </div>

  <div class="hero-scroll">
    <div class="scroll-bar"></div>
  </div>
</section>

<style>
  @keyframes orbDrift1 {
    0%,100%{ transform:translate(0,0) scale(1); }
    50%    { transform:translate(60px,-80px) scale(1.1); }
  }
  @keyframes orbDrift2 {
    0%,100%{ transform:translate(0,0); }
    50%    { transform:translate(-50px,60px) scale(1.08); }
  }
  @keyframes scrollAnim {
    0%   { transform:scaleY(0); transform-origin:top; opacity:0; }
    40%  { transform:scaleY(1); opacity:1; }
    100% { transform:scaleY(1); transform-origin:bottom; opacity:0; }
  }
  @keyframes fadeUp {
    from{ opacity:0; transform:translateY(24px); }
    to  { opacity:1; transform:translateY(0); }
  }

  .hero {
    min-height: 100svh;
    background: #07101f;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: 100px 24px 80px;
    text-align: center;
  }

  .hero-bg { position:absolute; inset:0; pointer-events:none; }
  .orb {
    position:absolute; border-radius:50%;
    filter:blur(100px); will-change:transform;
  }
  .orb-1 {
    width:600px; height:600px; top:-150px; left:-150px;
    background:radial-gradient(circle,rgba(29,78,216,.5) 0%,transparent 65%);
    animation:orbDrift1 20s ease-in-out infinite;
  }
  .orb-2 {
    width:500px; height:500px; bottom:-100px; right:-100px;
    background:radial-gradient(circle,rgba(99,102,241,.4) 0%,transparent 65%);
    animation:orbDrift2 24s ease-in-out infinite;
  }

  .hero-inner {
    position:relative; z-index:1;
    display:flex; flex-direction:column; align-items:center;
    max-width:680px; width:100%;
  }

  .hero-label {
    font-size:.72rem; font-weight:700; letter-spacing:.18em;
    text-transform:uppercase; color:rgba(147,197,253,.7);
    margin-bottom:28px;
    animation:fadeUp .8s cubic-bezier(.16,1,.3,1) .1s both;
  }

  .hero-title {
    font-size:clamp(3.5rem,10vw,7.5rem);
    font-weight:900; letter-spacing:-.055em; line-height:.95;
    color:#fff; margin-bottom:28px;
    animation:fadeUp .9s cubic-bezier(.16,1,.3,1) .2s both;
  }
  .hero-accent { color:#3b82f6; display:block; }

  .hero-desc {
    font-size:1.05rem; color:rgba(255,255,255,.5);
    line-height:1.75; max-width:460px;
    margin-bottom:24px;
    animation:fadeUp .9s cubic-bezier(.16,1,.3,1) .35s both;
  }

  .hero-flow {
    display:flex; align-items:center; gap:10px; flex-wrap:wrap;
    justify-content:center; margin-bottom:40px;
    animation:fadeUp .9s cubic-bezier(.16,1,.3,1) .45s both;
  }
  .hero-flow span {
    font-size:.78rem; font-weight:700; letter-spacing:.08em;
    text-transform:uppercase; color:rgba(255,255,255,.75);
    background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.1);
    border-radius:7px; padding:6px 13px;
  }
  .hero-flow svg { color:rgba(255,255,255,.25); flex-shrink:0; }

  .hero-actions {
    display:flex; gap:12px; flex-wrap:wrap; justify-content:center;
    animation:fadeUp .9s cubic-bezier(.16,1,.3,1) .58s both;
  }
  .btn-store {
    display:inline-flex; align-items:center; gap:10px;
    padding:12px 20px;
    background:rgba(255,255,255,.07); border:1.5px solid rgba(255,255,255,.13);
    border-radius:12px; color:#fff; text-decoration:none;
    backdrop-filter:blur(8px);
    transition:background .2s, border-color .2s, transform .15s;
  }
  .btn-store:hover {
    background:rgba(255,255,255,.13); border-color:rgba(255,255,255,.3);
    transform:translateY(-2px);
  }
  .btn-store div { text-align:left; line-height:1.25; }
  .btn-store span { display:block; font-size:.58rem; opacity:.5; }
  .btn-store strong { display:block; font-size:.88rem; font-weight:700; }

  .hero-scroll {
    position:absolute; bottom:28px; left:50%; transform:translateX(-50%);
    z-index:1;
  }
  .scroll-bar {
    width:1.5px; height:44px;
    background:linear-gradient(to bottom,rgba(255,255,255,.55),transparent);
    animation:scrollAnim 2.2s ease-in-out infinite;
    transform-origin:top;
  }

  @media(max-width:600px){
    .hero{ padding:88px 16px 72px; }
    .hero-title{ font-size:clamp(3rem,14vw,4.5rem); }
    .hero-desc{ font-size:.95rem; }
    .hero-actions{ flex-direction:column; align-items:stretch; width:100%; max-width:280px; }
    .btn-store{ justify-content:center; }
  }
</style>
