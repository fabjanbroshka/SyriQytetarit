---
const problems = [
  {
    title: "Parkim i Parregullt",
    desc: "Automjete që bllokojnë trotuaret, daljet e emergjencës ose vendet e rezervuara për personat me aftësi të kufizuara.",
    icon: `<rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>`,
    color: "#ef4444",
  },
  {
    title: "Rrugë të Dëmtuara",
    desc: "Gropat, asfalti i çarë, bordurat e shembura dhe sipërfaqe të pasigurta për qarkullim.",
    icon: `<path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>`,
    color: "#f59e0b",
  },
  {
    title: "Ndotja",
    desc: "Hedhja ilegale e mbeturinave, ndotja mjedisore ose kontaminimi i hapësirave publike.",
    icon: `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,
    color: "#10b981",
  },
  {
    title: "Ndriçim i Prishur",
    desc: "Dritat e rrugëve të fikura, duke krijuar kushte të pasigurta për këmbësorët gjatë natës.",
    icon: `<line x1="12" y1="2" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="22"/><line x1="4.93" y1="4.93" x2="7.76" y2="7.76"/><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"/><line x1="2" y1="12" x2="6" y2="12"/><line x1="18" y1="12" x2="22" y2="12"/><line x1="4.93" y1="19.07" x2="7.76" y2="16.24"/><line x1="16.24" y1="7.76" x2="19.07" y2="4.93"/>`,
    color: "#8b5cf6",
  },
  {
    title: "Bllokimi i Trotuarit",
    desc: "Pengesa, mbeturina ndërtimi ose bimësi që bllokon shtigjet e këmbësorëve.",
    icon: `<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>`,
    color: "#3b82f6",
  },
  {
    title: "Sjellje e Rrezikshme",
    desc: "Ngasja e pakujdesshme, sjellja agresive ose rreziqe të tjera në zonat publike.",
    icon: `<path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>`,
    color: "#ec4899",
  },
];
---

<section class="what-section" id="what">
  <div class="container">

    <header class="section-header">
      <span class="eyebrow">Çfarë është?</span>
      <h2 class="section-title">
        Një aplikacion për raportimin<br/>e problemeve të qytetit.
      </h2>
      <p class="section-sub">
        Si parkimi i parregullt, rrugët e dëmtuara, ndotja dhe shumë të tjera —
        raportoni çdo problem brenda 30 sekondave, direkt nga telefoni juaj.
      </p>
    </header>

    <div class="cards-grid">
      {problems.map((p, i) => (
        <div class="card" style={`--c:${p.color}; --delay:${i * 0.07}s`}>
          <div class="card-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round"
                 stroke-linejoin="round" set:html={p.icon}/>
          </div>
          <h3>{p.title}</h3>
          <p>{p.desc}</p>
          <div class="card-bar"></div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  @keyframes cardIn {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .what-section {
    background: #fff;
    padding: 112px 0;
  }

  .container {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .section-header {
    max-width: 600px;
    margin-bottom: 64px;
  }

  .eyebrow {
    display: inline-block;
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: #2563eb;
    margin-bottom: 14px;
  }

  .section-title {
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    font-weight: 800;
    letter-spacing: -.035em;
    line-height: 1.1;
    color: #0a0f1a;
    margin-bottom: 16px;
  }

  .section-sub {
    font-size: 1rem;
    color: #64748b;
    line-height: 1.75;
    max-width: 480px;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .card {
    position: relative;
    background: #f8fafc;
    border: 1.5px solid #e2e8f0;
    border-radius: 16px;
    padding: 28px 24px 32px;
    overflow: hidden;
    transition: border-color .25s, transform .25s, box-shadow .25s;
    opacity: 0;
    animation: cardIn .6s cubic-bezier(.16,1,.3,1) var(--delay, 0s) forwards;
  }
  .card:hover {
    border-color: var(--c);
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0,0,0,.07);
  }

  .card-icon {
    width: 44px; height: 44px;
    border-radius: 12px;
    background: color-mix(in srgb, var(--c) 12%, transparent);
    color: var(--c);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 18px;
  }

  .card h3 {
    font-size: .92rem;
    font-weight: 700;
    color: #0a0f1a;
    margin-bottom: 8px;
  }

  .card p {
    font-size: .82rem;
    color: #64748b;
    line-height: 1.65;
  }

  .card-bar {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 3px;
    background: var(--c);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform .3s cubic-bezier(.16,1,.3,1);
  }
  .card:hover .card-bar { transform: scaleX(1); }

  @media (max-width: 900px) {
    .what-section { padding: 80px 0; }
    .container { padding: 0 20px; }
    .cards-grid { grid-template-columns: repeat(2, 1fr); gap: 14px; }
    .section-header { margin-bottom: 48px; }
  }
  @media (max-width: 560px) {
    .what-section { padding: 64px 0; }
    .container { padding: 0 16px; }
    .cards-grid { grid-template-columns: 1fr; gap: 10px; }
    .section-title { font-size: clamp(1.75rem, 7vw, 2.4rem); }
  }
</style>
